      "approval_status": "verified_for_prototype_build",
      "review_status": "verified_for_prototype_build"
    },
    {
      "chunk_id": "POL-2025-05-P23-C01",
      "source_label": "ECCE Policy 2025, paragraph 23",
      "section_title": "Definition of ECCE",
      "chunk_text": "ECCE programmes provide children with care and a structured, purposeful set of learning activities either in formal institutions or non-formal child development programmes before primary education.",
      "topic_tags": [
        "policy_foundation",
        "curriculum_learning_transition"
      ],
      "role_tags": [
        "MoES Officer",
        "District Officer",
        "Teacher/Caregiver",
