      ],
      "approval_status": "verified_for_prototype_build",
      "review_status": "verified_for_prototype_build"
    },
    {
      "chunk_id": "POL-2025-05-P24-C01",
      "source_label": "ECCE Policy 2025, paragraph 24",
      "section_title": "Target Age Groups",
      "chunk_text": "The ECCE Policy targets two categories of children: birth to three years and three to six years.",
      "topic_tags": [
        "policy_foundation",
        "access_equity_inclusion"
      ],
      "role_tags": [
        "MoES Officer",
        "District Officer",
        "Teacher/Caregiver",
        "Parent/Guardian",
        "ECCE Proprietor"
      ],
      "approval_status": "verified_for_prototype_build",
      "review_status": "verified_for_prototype_build"
    },
    {
      "chunk_id": "POL-2025-05-P26-C01",
      "source_label": "ECCE Policy 2025, paragraph 26",
      "section_title": "Guiding Principles",
      "chunk_text": "ECCE implementation is guided by effectiveness, efficiency, child welfare, holistic approach, equitable access and non-discrimination, appropriate partnerships and communication in familiar language. Decisions must be based on age-appropriate programming and the best interests of the child.",
      "topic_tags": [
        "policy_foundation",
        "child_safety_protection",
        "access_equity_inclusion",
        "cross_cutting_issues"
      ],
      "role_tags": [
        "MoES Officer",
        "District Officer",
        "Inspector",
        "Teacher/Caregiver",
        "Parent/Guardian"
      ],
      "approval_status": "verified_for_prototype_build",
      "review_status": "verified_for_prototype_build"
    },
    {
      "chunk_id": "POL-2025-06-P28-C01",
      "source_label": "ECCE Policy 2025, paragraph 28",
      "section_title": "Underserved Communities",
      "chunk_text": "Government will increase access by identifying and allocating sustainable targeted subsidies for non-state ECCE provision in underserved communities and by developing strategies for learning materials and inputs in under-resourced communities.",
      "topic_tags": [
        "access_equity_inclusion",
        "financing_partnerships"
      ],
      "role_tags": [
        "MoES Officer",
        "District Officer",
        "CSO/Partner"
