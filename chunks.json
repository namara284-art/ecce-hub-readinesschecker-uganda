      "approval_status": "verified_for_prototype_build",
      "review_status": "verified_for_prototype_build"
    },
    {
      "chunk_id": "POL-2025-05-P21-C01",
      "source_label": "ECCE Policy 2025, paragraph 21",
      "section_title": "Policy Goal",
      "chunk_text": "The Policy Goal is to attain adequate ECCE services to improve child growth and development, educational outcomes, health outcomes and socio-economic development.",
      "topic_tags": [
        "policy_foundation"
      ],
      "role_tags": [
        "MoES Officer",
        "District Officer",
        "Parent/Guardian",
        "CSO/Partner"
