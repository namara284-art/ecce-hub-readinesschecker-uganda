      "approval_status": "verified_for_prototype_build",
      "review_status": "verified_for_prototype_build"
    },
    {
      "chunk_id": "POL-2025-05-P20-C01",
      "source_label": "ECCE Policy 2025, paragraph 20",
      "section_title": "Policy Mission",
      "chunk_text": "The Policy Mission is to support, standardise, guide, implement, coordinate, monitor, evaluate, regulate and promote quality, relevant and affordable ECCE services for increased access, equitable enrolment and smooth transition to primary education.",
      "topic_tags": [
        "policy_foundation",
        "access_equity_inclusion",
        "standards_compliance",
        "monitoring_evaluation_data"
      ],
      "role_tags": [
