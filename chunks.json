    },
    {
      "chunk_id": "POL-2025-03-P14-C01",
      "source_label": "ECCE Policy 2025, paragraph 14",
      "section_title": "Problem Statement",
      "chunk_text": "Quality ECCE is constrained by limited access, ineffective regulation, lack of knowledge on the value of ECCE, inconsistent family and community engagement, uncoordinated efforts, poverty, high cost of services and limited access to quality ECCE data.",
      "topic_tags": [
        "policy_foundation",
        "registration_licensing",
