      "approval_status": "verified_for_prototype_build",
      "review_status": "verified_for_prototype_build"
    },
    {
      "chunk_id": "POL-2025-06-P30-C01",
      "source_label": "ECCE Policy 2025, paragraph 30",
      "section_title": "Day Care and Pre-Primary",
      "chunk_text": "Government will streamline quality ECCE through day care offered in homes or institutions for birth to three years and pre-primary programmes for children aged three to six years.",
      "topic_tags": [
        "registration_licensing",
        "policy_foundation",
        "curriculum_learning_transition"
      ],
      "role_tags": [
        "ECCE Proprietor",
        "District Officer",
        "Parent/Guardian",
        "MoES Officer"
      ],
      "approval_status": "verified_for_prototype_build",
      "review_status": "verified_for_prototype_build"
    },
    {
      "chunk_id": "POL-2025-06-P31-C01",
      "source_label": "ECCE Policy 2025, paragraph 31",
      "section_title": "Direct Government Provision",
      "chunk_text": "Government will engage in direct ECCE service delivery in areas with no viable private sector provider, as an affirmative intervention.",
      "topic_tags": [
        "access_equity_inclusion",
        "financing_partnerships"
      ],
      "role_tags": [
        "MoES Officer",
        "District Officer",
        "CSO/Partner"
      ],
      "approval_status": "verified_for_prototype_build",
      "review_status": "verified_for_prototype_build"
    },
    {
      "chunk_id": "POL-2025-06-P32-C01",
      "source_label": "ECCE Policy 2025, paragraph 32",
      "section_title": "Licensing and Boarding Prohibition",
      "chunk_text": "Government will license ECCE centres and primary schools to offer day care and pre-primary programmes. Licensing processes are managed by City, District, Municipal or Local Government authorities. ECCE centres are prohibited from operating as boarding institutions at registration or licensing stage.",
      "topic_tags": [
        "registration_licensing",
        "standards_compliance",
        "inspection_supervision"
      ],
      "role_tags": [
        "District Officer",
        "Inspector",
        "ECCE Proprietor",
        "MoES Officer"
      ],
      "approval_status": "verified_for_prototype_build",
      "review_status": "verified_for_prototype_build"
    },
    {
      "chunk_id": "POL-2025-06-P33-C01",
      "source_label": "ECCE Policy 2025, paragraph 33",
      "section_title": "Provisional and Full Licensing",
      "chunk_text": "There will be a provisional licence for one year followed by full licensing upon satisfactory service delivery and meeting Basic Requirements and Minimum Standards. Registered and licensed centres will be subject to periodic inspection, and licences may be revoked if quality is compromised.",
      "topic_tags": [
        "registration_licensing",
        "standards_compliance",
        "inspection_supervision"
      ],
      "role_tags": [
        "District Officer",
        "Inspector",
        "ECCE Proprietor",
        "MoES Officer"
      ],
      "approval_status": "verified_for_prototype_build",
      "review_status": "verified_for_prototype_build"
    },
    {
