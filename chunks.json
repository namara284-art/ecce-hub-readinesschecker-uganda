      "review_status": "verified_for_prototype_build"
    },
    {
      "chunk_id": "POL-2025-05-P19-C01",
      "source_label": "ECCE Policy 2025, paragraph 19",
      "section_title": "Policy Vision",
      "chunk_text": "The Policy Vision is a country where there is equitable and sustainable access to quality Early Childhood Care and Education services.",
      "topic_tags": [
        "policy_foundation"
      ],
      "role_tags": [
        "MoES Officer",
        "District Officer",
        "CSO/Partner"
